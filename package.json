{
  "name": "expo-spartatigers",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "prepare": "husky",
    "dev": "REACT_NATIVE_PACKAGER_HOSTNAME=172.30.1.23 expo start --clear --host lan",
    "check:all": "npx eslint . && npx tsc --noEmit && npx expo-doctor",
    "arch:reset-project": "node ./scripts/architecture-guard/utils/reset-project.js",
    "arch:all": "npm run arch:dep && npm run arch:fat",
    "arch:dep": "npx depcruise app components context hooks src styles --exclude '^node_modules' --output-type json > scripts/architecture-guard/dependency/reports/dependency-report.json && (cd scripts/architecture-guard/dependency/reports && python3 ../analyze_deps.py > analysis_results.txt)",
    "arch:dep-validate": "depcruise --validate app components context hooks src styles",
    "arch:fat": "tsx scripts/architecture-guard/fat-file/index.ts",
    "arch:fat-typecheck": "tsc -p scripts/architecture-guard/fat-file/tsconfig.json --noEmit",
    "arch:fat-baseline": "tsx scripts/architecture-guard/fat-file/verifier/capture-baseline.ts scripts/architecture-guard/fat-file/verifier/tsc-baseline.txt",
    "format": "prettier --write \"**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@hookform/resolvers": "^5.4.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/checkbox": "^0.5.20",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-community/slider": "^5.2.0",
    "@react-native-menu/menu": "^2.0.0",
    "@react-native-picker/picker": "^2.11.4",
    "@react-navigation/bottom-tabs": "^7.18.8",
    "@react-navigation/elements": "^2.9.30",
    "@react-navigation/native": "^7.3.8",
    "@react-navigation/native-stack": "^7.17.10",
    "@shopify/flash-list": "2.0.2",
    "@stomp/stompjs": "^7.2.1",
    "@tanstack/query-async-storage-persister": "^5.101.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-persist-client": "^5.101.2",
    "axios": "^1.18.1",
    "expo": "^57.0.4",
    "expo-build-properties": "~57.0.3",
    "expo-constants": "~57.0.3",
    "expo-device": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-image-manipulator": "~57.0.2",
    "expo-image-picker": "~57.0.2",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-location": "~57.0.2",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.4",
    "expo-secure-store": "~57.0.0",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "fast-text-encoding": "^1.0.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-error-boundary": "^6.1.2",
    "react-hook-form": "^7.81.0",
    "react-native": "^0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-image-viewing": "^0.2.2",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-map-clustering": "^4.0.0",
    "react-native-maps": "1.27.2",
    "react-native-pager-view": "8.0.2",
    "react-native-paper": "^5.15.3",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-tab-view": "^4.3.1",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "sockjs-client": "^1.6.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@types/react": "^19.2.17",
    "@types/sockjs-client": "^1.5.4",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^9.39.5",
    "eslint-config-expo": "~57.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-native": "^5.0.0",
    "fast-check": "^4.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.9.5",
    "ts-morph": "^28.0.0",
    "tsx": "^4.23.0",
    "typescript": "~6.0.3"
  },
  "lint-staged": {
    "app/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --max-warnings=0"
    ],
    "components/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --max-warnings=0"
    ],
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --max-warnings=0"
    ],
    "context/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --max-warnings=0"
    ],
    "hooks/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --max-warnings=0"
    ]
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@react-native-community/checkbox"
        ],
        "listUnknownPackages": false
      }
    }
  }
}
