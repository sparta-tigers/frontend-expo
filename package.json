{
  "name": "expo-spartatigers",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "prepare": "husky",
    "dev": "REACT_NATIVE_PACKAGER_HOSTNAME=172.30.1.23 expo start --clear --host lan",
    "check:all": "npx eslint . && npx tsc --noEmit && npx expo-doctor",
    "arch:reset-project": "node ./scripts/architecture-guard/utils/reset-project.js",
    "arch:all": "npm run arch:dep && npm run arch:fat",
    "arch:dep": "npx depcruise app components context hooks src styles --exclude '^node_modules' --output-type json > scripts/architecture-guard/dependency/reports/dependency-report.json && (cd scripts/architecture-guard/dependency/reports && python3 ../analyze_deps.py > analysis_results.txt)",
    "arch:dep-validate": "depcruise --validate app components context hooks src styles",
    "arch:fat": "tsx scripts/architecture-guard/fat-file/index.ts",
    "arch:fat-typecheck": "tsc -p scripts/architecture-guard/fat-file/tsconfig.json --noEmit",
    "arch:fat-baseline": "tsx scripts/architecture-guard/fat-file/verifier/capture-baseline.ts scripts/architecture-guard/fat-file/verifier/tsc-baseline.txt"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/checkbox": "^0.5.20",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-community/slider": "5.0.1",
    "@react-native-menu/menu": "^2.0.0",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.16",
    "@shopify/flash-list": "2.0.2",
    "@stomp/stompjs": "^7.2.1",
    "@tanstack/query-async-storage-persister": "^5.100.9",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-query-persist-client": "^5.100.9",
    "axios": "^1.13.2",
    "expo": "~54.0.34",
    "expo-constants": "~18.0.13",
    "expo-device": "^8.0.10",
    "expo-file-system": "^19.0.21",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.21",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "fast-text-encoding": "^1.0.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.71.2",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-image-viewing": "^0.2.2",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-map-clustering": "^4.0.0",
    "react-native-maps": "1.20.1",
    "react-native-pager-view": "6.9.1",
    "react-native-paper": "^5.15.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.5",
    "react-native-tab-view": "^4.2.2",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "sockjs-client": "^1.6.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@types/react": "~19.1.0",
    "@types/sockjs-client": "^1.5.4",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-plugin-react-native": "^5.0.0",
    "fast-check": "4.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "tsx": "4.20.6",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "app/**/*.{ts,tsx}": [
      "eslint --max-warnings=0"
    ],
    "components/**/*.{ts,tsx}": [
      "eslint --max-warnings=0"
    ],
    "src/**/*.{ts,tsx}": [
      "eslint --max-warnings=0"
    ],
    "context/**/*.{ts,tsx}": [
      "eslint --max-warnings=0"
    ],
    "hooks/**/*.{ts,tsx}": [
      "eslint --max-warnings=0"
    ]
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@react-native-community/checkbox"
        ],
        "listUnknownPackages": false
      }
    }
  }
}
