{
  // Feature: fat-file-refactoring
  // Node.js ESM script scope, executed via `tsx`.
  // Intentionally detached from the root Expo tsconfig:
  //   - No JSX, no DOM lib, no react-native condition.
  //   - strict + isolatedModules to keep each file independently transpilable (matches tsx/esbuild).
  //   - noEmit because tsx compiles on the fly.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["node"],

    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,

    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "noEmit": true
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
